VITE_APP_NAME=Entaltek Rentas
VITE_PUBLIC_BASE_URL=http://localhost:5173

# Opcional. Si se define, la app usa este backend REST en lugar del
# almacenamiento local del navegador. Contrato esperado:
#   GET/POST  /api/properties
#   GET       /api/properties/:id
#   GET       /api/properties/slug/:slug
#   PUT       /api/properties/:id
#   PATCH     /api/properties/:id/publish
#   PATCH     /api/properties/:id/unpublish
#   DELETE    /api/properties/:id
