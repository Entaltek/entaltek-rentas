VITE_APP_NAME=Entaltek Rentas
VITE_PUBLIC_BASE_URL=http://localhost:5173

# Supabase directo desde frontend.
# Copia este archivo como .env.local y pega tu publishable key real ahí.
# No subas .env.local al repositorio.
VITE_SUPABASE_URL=https://begtjpyyifvxfarqwcic.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=tu_publishable_key_de_supabase

# Opcional. Si se define, la app usa este backend REST antes que Supabase.
# Contrato esperado:
#   GET/POST  /api/properties
#   GET       /api/properties/:id
#   GET       /api/properties/slug/:slug
#   PUT       /api/properties/:id
#   PATCH     /api/properties/:id/publish
#   PATCH     /api/properties/:id/unpublish
#   DELETE    /api/properties/:id
# VITE_API_BASE_URL=http://localhost:8000
