# Application
APP_ENV=development
DEBUG=true

# Database (async URL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/entaltek_rentas

# CORS — comma-separated origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# Storage backend: local | s3 | r2 | supabase
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=media
STORAGE_BASE_URL=http://localhost:8000/media

# Cloud storage (fill when STORAGE_BACKEND != local)
# STORAGE_BUCKET=my-bucket
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
# STORAGE_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STORAGE_ENDPOINT_URL=https://xxxxx.r2.cloudflarestorage.com

# Image limits
IMAGE_MAX_SIZE_BYTES=10485760
IMAGES_PER_PROPERTY_MAX=20
